# Server
PORT=3001
NODE_ENV=development
DB_PATH=./db/adforge.db
LOG_LEVEL=info

# Security (REQUIRED)
JWT_SECRET=           # REQUIRED - no default, server will not start without it
CORS_ORIGIN=http://localhost:5173

# LLM / AI
OMNIROUTE_URL=http://localhost:20128/v1/chat/completions
OMNIROUTE_MODEL=auto/pro-fast
OMNIROUTE_API_KEY=
LLM_TIMEOUT=30000

# Ad Platform APIs
META_ACCESS_TOKEN=
FB_SYSTEM_TOKEN=
GOOGLE_ADS_CREDENTIALS_PATH=
TIKTOK_ACCESS_TOKEN=

# External Services
BK_HUB_URL=http://localhost:9099
COMPETITOR_URLS=
TRENDING_EXTERNAL_SOURCE=mock
